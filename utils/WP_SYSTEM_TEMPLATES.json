                        ]
                    }
                },
                {
                    "type": "BODY",
                    "text": "Dear *{{1}}*,\n\nKindly clear your due of *Rs. {{2}}* to  *{{3}}* as soon as possible.\n\nThanks and Regards\nTeam *{{4}}* your Compliance Partner",
                    "example": {
                        "body_text": [
